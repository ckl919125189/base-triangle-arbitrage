# Base Triangle Arbitrage - Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# NETWORK
# ===================
NODE_ENV=development

# RPC URL (Base Mainnet)
RPC_URL=https://mainnet.base.org

# Private Key (without 0x prefix) - USE CAUTION
PRIVATE_KEY=your_private_key_here

# ===================
# CONTRACT ADDRESSES
# ===================
# Uniswap V3 Router on Base
SWAP_ROUTER=0x1FEd653d9b6679d0a85d1d7A42C4FA214f29C608

# Fee collector address (where protocol fees go)
FEE_COLLECTOR=0x0000000000000000000000000000000000000000

# Aave Pool for flash loans (optional)
AAVE_POOL=0xA238Dd80C259a72e5d7f8a4d06FC6285dD7B1E66

# ===================
# TRADING PARAMETERS
# ===================
# Minimum profit threshold (in ETH)
MIN_PROFIT_THRESHOLD=0.001

# Slippage tolerance (basis points, 300 = 3%)
SLIPPAGE_TOLERANCE=300

# Max slippage for emergency exits
MAX_SLIPPAGE=500

# ===================
# GAS SETTINGS
# ===================
# Gas price (auto or in gwei)
GAS_PRICE=auto

# Gas limit for transactions
GAS_LIMIT=500000

# ===================
# DASHBOARD
# ===================
# Dashboard port
DASHBOARD_PORT=3000

# Dashboard host
DASHBOARD_HOST=localhost

# ===================
# MONITORING
# ===================
# Price update interval (ms)
PRICE_UPDATE_INTERVAL=5000

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ===================
# API KEYS (Optional)
# ===================
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
